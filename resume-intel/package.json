{
  "name": "resume-intel",
  "version": "1.0.0",
  "description": "Resume Intelligence desktop app for recruiters",
  "main": "./out/main/index.js",
  "type": "module",
  "author": "Resume Intel",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "stage:browsers": "node scripts/stage-playwright-browsers.mjs",
    "build:win": "npm run build && npm run stage:browsers && electron-builder --win",
    "build:mac": "npm run build && npm run stage:browsers && electron-builder --mac",
    "dist": "npm run build && npm run stage:browsers && electron-builder --win --mac",
    "verify": "node scripts/verify.mjs",
    "mark-done": "node scripts/mark-feature-done.mjs",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "electron-store": "^10.0.0",
    "mammoth": "^1.9.0",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.51.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5",
    "xlsx-js-style": "^1.2.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.51.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.39.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.5.0",
    "jszip": "^3.10.1",
    "vite": "^5.4.11",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "com.resumeintel.app",
    "productName": "Resume Intel",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ],
    "extraResources": [
      {
        "from": "resources/browsers",
        "to": "browsers",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "Resume-Intel-Setup-${version}.${ext}"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "artifactName": "Resume-Intel-${version}.${ext}",
      "identity": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "dmg": {
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  }
}
